# Copier vers .env.local et remplir les valeurs.
# NE JAMAIS commiter de valeurs réelles.

# Supabase — Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role — UNIQUEMENT pour scripts/import-data.ts en local.
# Bypasse le RLS : ne jamais l'exposer côté client ni la déployer.
SUPABASE_SERVICE_ROLE_KEY=

# URL publique du site (sitemap, métadonnées)
NEXT_PUBLIC_SITE_URL=https://example.com
